{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "cppbuild",
			"label": "C/C++: gcc 生成活动文件",
			"command": "/usr/bin/gcc",
			"args": [
				"-fdiagnostics-color=always",
				"-g",
				"${file}",
				"-o",
				"${fileDirname}/${fileBasenameNoExtension}"
			],
			"options": {
				"cwd": "${fileDirname}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": "build",
			"detail": "编译器: /usr/bin/gcc"
		},
		{
			"type": "shell",
			"label": "CUDA C++",
			"command": "nvcc",
			"args": [
				"-std=c++17",
				"-g",
				"-G",
				"-o",
				"${fileDirname}/${fileBasenameNoExtension}",
				"${file}",
				"-lcublas"
			]
		}
	]
}